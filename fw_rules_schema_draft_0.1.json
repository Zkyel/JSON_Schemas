{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["name", "rules"],
    "properties": {
      "name": {
        "type": "string",
        "minLength": 1,
        "description": "Name of the rule group"
      },
      "rules": {
        "oneOf": [
          { "$ref": "#/definitions/rule" },
          {
            "type": "array",
            "items": { "$ref": "#/definitions/rule" },
            "minItems": 1,
            "uniqueItems": true
          }
        ]
      }
    },
    "additionalProperties": false
  },

  "definitions": {
    "ip_or_fqdn": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^(\\d{1,3}\\.){3}\\d{1,3}(\\s*\\/\\d{1,2})?$",
          "description": "IPv4 address or CIDR"
        },
        {
          "type": "string",
          "pattern": "^(?=.{1,255}$)([a-zA-Z0-9]([-a-zA-Z0-9]*[a-zA-Z0-9])?\\.)+[a-zA-Z]{2,}$",
          "description": "Fully Qualified Domain Name (FQDN)"
        },
        {
          "type": "object",
          "required": ["address"],
          "properties": {
            "address": {
              "type": "string",
              "oneOf": [
                {
                  "pattern": "^(\\d{1,3}\\.){3}\\d{1,3}(\\s*\\/\\d{1,2})?$",
                  "description": "IPv4 address or CIDR"
                },
                {
                  "pattern": "^(?=.{1,255}$)([a-zA-Z0-9]([-a-zA-Z0-9]*[a-zA-Z0-9])?\\.)+[a-zA-Z]{2,}$",
                  "description": "Fully Qualified Domain Name (FQDN)"
                }
              ]
            },
            "description": {
              "type": "string",
              "description": "Description for the IP, CIDR, or FQDN"
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["address_list"],
          "properties": {
            "address_list": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "oneOf": [
                  {
                    "type": "string",
                    "pattern": "^(\\d{1,3}\\.){3}\\d{1,3}(\\s*\\/\\d{1,2})?$"
                  },
                  {
                    "type": "string",
                    "pattern": "^(?=.{1,255}$)([a-zA-Z0-9]([-a-zA-Z0-9]*[a-zA-Z0-9])?\\.)+[a-zA-Z]{2,}$"
                  }
                ]
              },
              "description": "List of IPs, CIDRs or FQDNs"
            },
            "description": {
              "type": "string",
              "description": "Description for the list of addresses"
            }
          },
          "additionalProperties": false
        }
      ]
    },

    "service_value": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^(?:tcp|udp)\\/(?:\\d+(?:\\s*-\\s*\\d+)?(?:,\\d+(?:\\s*-\\s*\\d+)?)*)$|^(?:icmp|any)$",
          "description": "Protocol and optional port in the form 'protocol/port', 'protocol/port,port' or 'protocol/port-port'"
        },
        {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^(?:tcp|udp)\\/(?:\\d+(?:\\s*-\\s*\\d+)?(?:,\\d+(?:\\s*-\\s*\\d+)?)*)$|^(?:icmp|any)$"
          },
          "minItems": 1,
          "uniqueItems": true,
          "description": "List of protocol/port entries"
        }
      ]
    },

    "responder_with_service": {
      "oneOf": [
        {
          "type": "object",
          "required": ["address", "service"],
          "properties": {
            "address": {
              "type": "string",
              "oneOf": [
                {
                  "pattern": "^(\\d{1,3}\\.){3}\\d{1,3}(\\s*\\/\\d{1,2})?$",
                  "description": "IPv4 address or CIDR"
                },
                {
                  "pattern": "^(?=.{1,255}$)([a-zA-Z0-9]([-a-zA-Z0-9]*[a-zA-Z0-9])?\\.)+[a-zA-Z]{2,}$",
                  "description": "Fully Qualified Domain Name (FQDN)"
                }
              ]
            },
            "description": {
              "type": "string",
              "description": "Description for the address"
            },
            "service": { "$ref": "#/definitions/service_value" }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["address_list", "service"],
          "properties": {
            "address_list": {
              "type": "array",
              "minItems": 1,
              "uniqueItems": true,
              "items": {
                "oneOf": [
                  {
                    "type": "string",
                    "pattern": "^(\\d{1,3}\\.){3}\\d{1,3}(\\s*\\/\\d{1,2})?$"
                  },
                  {
                    "type": "string",
                    "pattern": "^(?=.{1,255}$)([a-zA-Z0-9]([-a-zA-Z0-9]*[a-zA-Z0-9])?\\.)+[a-zA-Z]{2,}$"
                  }
                ]
              },
              "description": "List of IPs, CIDRs or FQDNs"
            },
            "description": {
              "type": "string",
              "description": "Description for the list of addresses"
            },
            "service": { "$ref": "#/definitions/service_value" }
          },
          "additionalProperties": false
        }
      ]
    },

    "rule": {
      "type": "object",
      "required": ["id", "action", "initiator", "responder"],
      "properties": {
        "id": {
          "type": "integer",
          "minimum": 1
        },
        "action": {
          "type": "string",
          "enum": ["allow", "deny"]
        },
        "initiator": {
          "oneOf": [
            { "$ref": "#/definitions/ip_or_fqdn" },
            {
              "type": "array",
              "items": { "$ref": "#/definitions/ip_or_fqdn" },
              "minItems": 1,
              "uniqueItems": true
            }
          ]
        },
        "responder": {
          "oneOf": [
            { "$ref": "#/definitions/responder_with_service" },
            {
              "type": "array",
              "items": { "$ref": "#/definitions/responder_with_service" },
              "minItems": 1,
              "uniqueItems": true
            }
          ]
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
